{
  "name": "DockerCredential",
  "kind": "DockerCredential",
  "provider": "docker",
  "apiVersion": "connect.planton.ai/v1",
  "description": "Docker container registry credential supporting GCP Artifact Registry, AWS ECR, Azure ACR, JFrog Artifactory, and GitHub Container Registry.",
  "spec": {
    "name": "DockerCredentialSpec",
    "fields": [
      {"name": "provider", "type": "enum", "enumValues": ["gcp_artifact_registry", "aws_elastic_container_registry", "azure_container_registry", "jfrog_artifactory", "github_container_registry"], "description": "Docker repository provider type.", "required": true},
      {"name": "gcp_artifact_registry", "type": "object", "description": "GCP Artifact Registry credentials. Required when provider=gcp_artifact_registry.", "required": false, "fields": [
        {"name": "gcp_project_id", "type": "string", "description": "GCP project ID.", "required": true},
        {"name": "gcp_region", "type": "string", "description": "GCP region.", "required": true},
        {"name": "service_account_key_base64", "type": "string", "description": "Base64-encoded service account key.", "required": true, "sensitive": true},
        {"name": "gcp_artifact_registry_repo_name", "type": "string", "description": "Artifact Registry repository name.", "required": true}
      ]},
      {"name": "aws_elastic_container_registry", "type": "object", "description": "AWS ECR credentials. Required when provider=aws_elastic_container_registry.", "required": false, "fields": [
        {"name": "account_id", "type": "string", "description": "AWS account ID.", "required": true},
        {"name": "access_key_id", "type": "string", "description": "AWS access key ID.", "required": true},
        {"name": "secret_access_key", "type": "string", "description": "AWS secret access key.", "required": true, "sensitive": true},
        {"name": "region", "type": "string", "description": "AWS region.", "required": true}
      ]},
      {"name": "github_container_registry", "type": "object", "description": "GitHub Container Registry (ghcr.io) credentials. Required when provider=github_container_registry.", "required": false, "fields": [
        {"name": "github_username", "type": "string", "description": "GitHub username.", "required": true},
        {"name": "personal_access_token", "type": "string", "description": "GitHub PAT for ghcr.io.", "required": true, "sensitive": true}
      ]}
    ]
  }
}
