{
  "name": "PulumiBackendCredential",
  "kind": "PulumiBackendCredential",
  "provider": "pulumi",
  "apiVersion": "connect.planton.ai/v1",
  "description": "Pulumi state backend credential supporting HTTP (Pulumi Cloud), S3, GCS, and Azure Blob Storage backends.",
  "spec": {
    "name": "PulumiBackendCredentialSpec",
    "fields": [
      {"name": "type", "type": "enum", "enumValues": ["http", "s3", "gcs", "azurerm"], "description": "Pulumi backend type.", "required": true},
      {"name": "http", "type": "object", "description": "Pulumi Cloud (HTTP) backend. Required when type=http.", "required": false, "fields": [
        {"name": "api_url", "type": "string", "description": "Pulumi Cloud API URL.", "required": false},
        {"name": "pulumi_organization", "type": "string", "description": "Pulumi Cloud organization.", "required": true},
        {"name": "access_token", "type": "string", "description": "Pulumi Cloud access token.", "required": true, "sensitive": true}
      ]},
      {"name": "s3", "type": "object", "description": "S3 backend. Required when type=s3.", "required": false, "fields": [
        {"name": "s3_bucket", "type": "string", "description": "S3 bucket name.", "required": true},
        {"name": "aws_access_key_id", "type": "string", "description": "AWS access key ID.", "required": true},
        {"name": "aws_secret_access_key", "type": "string", "description": "AWS secret access key.", "required": true, "sensitive": true},
        {"name": "endpoint", "type": "string", "description": "Custom S3 endpoint. Optional.", "required": false},
        {"name": "region", "type": "string", "description": "AWS region. Optional.", "required": false}
      ]},
      {"name": "gcs", "type": "object", "description": "GCS backend. Required when type=gcs.", "required": false, "fields": [
        {"name": "gcs_bucket", "type": "string", "description": "GCS bucket name.", "required": true},
        {"name": "service_account_key_base64", "type": "string", "description": "Base64-encoded service account key.", "required": true, "sensitive": true}
      ]},
      {"name": "azurerm", "type": "object", "description": "Azure Blob Storage backend. Required when type=azurerm.", "required": false, "fields": [
        {"name": "blob_storage_container", "type": "string", "description": "Azure Blob Storage container name.", "required": true},
        {"name": "storage_account_name", "type": "string", "description": "Azure Storage account name.", "required": true},
        {"name": "storage_account_key", "type": "string", "description": "Azure Storage account key.", "required": true, "sensitive": true}
      ]},
      {"name": "secrets_passphrase", "type": "string", "description": "Passphrase for encrypting secrets in DIY backends. Not needed for HTTP backend.", "required": false, "sensitive": true}
    ]
  }
}
