{
  "name": "MavenCredential",
  "kind": "MavenCredential",
  "provider": "maven",
  "apiVersion": "connect.planton.ai/v1",
  "description": "Maven repository credential supporting GCP Artifact Registry, JFrog Artifactory, and GitHub Packages.",
  "spec": {
    "name": "MavenCredentialSpec",
    "fields": [
      {"name": "provider", "type": "enum", "enumValues": ["gcp_artifact_registry", "jfrog_artifactory", "github_packages"], "description": "Maven repository provider type.", "required": true},
      {"name": "gcp_artifact_registry", "type": "object", "description": "GCP Artifact Registry credentials.", "required": false, "fields": [
        {"name": "gcp_project_id", "type": "string", "description": "GCP project ID.", "required": true},
        {"name": "gcp_region", "type": "string", "description": "GCP region.", "required": true},
        {"name": "service_account_key_base64", "type": "string", "description": "Base64-encoded service account key.", "required": true, "sensitive": true},
        {"name": "gcp_artifact_registry_repo_name", "type": "string", "description": "Artifact Registry repository name.", "required": true}
      ]},
      {"name": "github_packages", "type": "object", "description": "GitHub Packages credentials.", "required": false, "fields": [
        {"name": "github_username", "type": "string", "description": "GitHub username.", "required": true},
        {"name": "personal_access_token", "type": "string", "description": "GitHub PAT with read:packages/write:packages scopes.", "required": true, "sensitive": true}
      ]}
    ]
  }
}
