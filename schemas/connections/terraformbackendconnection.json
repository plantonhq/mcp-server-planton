{
  "name": "TerraformBackendConnection",
  "kind": "TerraformBackendConnection",
  "provider": "terraform",
  "apiVersion": "connect.planton.ai/v1",
  "description": "Terraform state backend connection supporting S3, GCS, and Azure Blob Storage backends.",
  "spec": {
    "name": "TerraformBackendConnectionSpec",
    "fields": [
      {"name": "type", "type": "enum", "enumValues": ["s3", "gcs", "azurerm"], "description": "Terraform backend type.", "required": true},
      {"name": "s3", "type": "object", "description": "S3 backend. Required when type=s3.", "required": false, "fields": [
        {"name": "bucket", "type": "string", "description": "S3 bucket name.", "required": true},
        {"name": "aws_access_key_id", "type": "string", "description": "AWS access key ID.", "required": true},
        {"name": "aws_secret_access_key", "type": "string", "description": "AWS secret access key.", "required": true, "sensitive": true},
        {"name": "region", "type": "string", "description": "AWS region.", "required": true},
        {"name": "dynamodb_table", "type": "string", "description": "DynamoDB table for state locking. Optional.", "required": false},
        {"name": "endpoint", "type": "string", "description": "Custom S3 endpoint. Optional.", "required": false}
      ]},
      {"name": "gcs", "type": "object", "description": "GCS backend. Required when type=gcs.", "required": false, "fields": [
        {"name": "gcs_bucket", "type": "string", "description": "GCS bucket name.", "required": true},
        {"name": "service_account_key_base64", "type": "string", "description": "Base64-encoded service account key.", "required": true, "sensitive": true}
      ]},
      {"name": "azurerm", "type": "object", "description": "Azure Blob Storage backend. Required when type=azurerm.", "required": false, "fields": [
        {"name": "resource_group_name", "type": "string", "description": "Azure resource group name.", "required": true},
        {"name": "storage_account_name", "type": "string", "description": "Azure Storage account name.", "required": true},
        {"name": "container_name", "type": "string", "description": "Azure Blob container name.", "required": true},
        {"name": "client_id", "type": "string", "description": "Azure Service Principal Client ID.", "required": true},
        {"name": "client_secret", "type": "string", "description": "Azure Service Principal Client Secret.", "required": true, "sensitive": true},
        {"name": "tenant_id", "type": "string", "description": "Azure AD Tenant ID.", "required": true},
        {"name": "subscription_id", "type": "string", "description": "Azure Subscription ID.", "required": true}
      ]}
    ]
  }
}
